# Local dev only. In Lambda, these come from the function's env vars (set by Terraform).
PORT=3000
ALLOWED_ORIGINS=http://localhost:5173
ITEMS_TABLE_NAME=portfolio-items
USERS_TABLE_NAME=portfolio-users
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
AWS_REGION=eu-north-1

# Uncomment to use DynamoDB Local (docker compose up) instead of real AWS DynamoDB.
# Also set fake credentials so the SDK doesn't complain:
#AWS_ENDPOINT_URL=http://localhost:8000
#AWS_ACCESS_KEY_ID=local
#AWS_SECRET_ACCESS_KEY=local
